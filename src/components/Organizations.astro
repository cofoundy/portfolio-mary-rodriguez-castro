---
import { siteConfig } from "../config";
const orgs = siteConfig.organizations;
const totalOrgs = orgs.length;
// Last 4 logos should be centered
const mainOrgs = orgs.slice(0, totalOrgs - 4);
const lastOrgs = orgs.slice(totalOrgs - 4);
---

<section class="relative py-12 md:py-14" style={`background-color: ${siteConfig.bgDark}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.03]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <h2 class="text-2xl md:text-3xl font-bold" style={`color: ${siteConfig.accentColor}`}>
        Organizaciones con las que he colaborado
      </h2>
      <div class="w-16 h-1 mt-3 mx-auto rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
    </div>

    <!-- Main logos grid -->
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4 md:gap-5 items-center justify-items-center reveal stagger-1">
      {mainOrgs.map((org) => (
        <div class="flex items-center justify-center w-full aspect-[3/2] p-4 rounded-xl transition-all duration-300 hover:scale-105 group">
          <img
            src={org.logo}
            alt={org.name}
            class="h-10 md:h-12 w-auto max-w-[100px] object-contain brightness-0 invert opacity-60 group-hover:opacity-90 transition-opacity duration-300"
            title={org.name}
          >
        </div>
      ))}
    </div>

    <!-- Last 4 logos centered -->
    <div class="flex justify-center gap-4 md:gap-5 mt-4 md:mt-5 reveal stagger-2">
      {lastOrgs.map((org) => (
        <div class="flex items-center justify-center w-[calc(25%-12px)] max-w-[150px] aspect-[3/2] p-4 rounded-xl transition-all duration-300 hover:scale-105 group">
          <img
            src={org.logo}
            alt={org.name}
            class="h-10 md:h-12 w-auto max-w-[100px] object-contain brightness-0 invert opacity-60 group-hover:opacity-90 transition-opacity duration-300"
            title={org.name}
          >
        </div>
      ))}
    </div>
  </div>
</section>
