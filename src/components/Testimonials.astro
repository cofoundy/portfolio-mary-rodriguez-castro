---
import { siteConfig } from "../config";
---

<section id="testimonials" class="relative py-12 md:py-16" style={`background-color: ${siteConfig.bgCard}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.03]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>
        Testimonios
      </h2>
      <div class="w-16 h-1 mt-3 mx-auto rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {siteConfig.testimonials.map((t, index) => (
        <div
          class={`reveal stagger-${index + 1} card-hover p-6 rounded-xl relative`}
          style={`background-color: ${siteConfig.bgDark}; border: 1px solid rgba(255,255,255,0.08)`}
        >
          <p class="text-sm leading-relaxed mb-6" style={`color: ${siteConfig.textLight}; font-style: italic`}>
            <span class="text-3xl font-serif leading-none opacity-40 mr-1 align-top" style={`color: ${siteConfig.highlightColor}`}>&ldquo;</span>{t.text}<span class="text-3xl font-serif leading-none opacity-40 ml-1 align-bottom" style={`color: ${siteConfig.highlightColor}`}>&rdquo;</span>
          </p>
          <div class="mt-auto pt-4 border-t" style="border-color: rgba(255,255,255,0.08)">
            <p class="text-sm font-semibold text-white">{t.author}</p>
            <p class="text-xs" style={`color: ${siteConfig.accentColor}`}>{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
