---
import { siteConfig } from "../config";
---

<section id="education" class="relative py-12 md:py-16" style={`background-color: ${siteConfig.bgDark}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.03]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
    <div class="mb-10 reveal-left">
      <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>Formación</h2>
      <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {siteConfig.education.map((edu, index) => (
        <div
          class={`reveal stagger-${(index % 4) + 1} card-hover flex gap-4 p-4 rounded-xl`}
          style={`background-color: ${siteConfig.bgCard}; border: 1px solid rgba(255,255,255,0.08)`}
        >
          <div class="flex-1 min-w-0">
            <h4 class="text-sm font-semibold text-white">{edu.degree}</h4>
            <p class="text-xs mt-0.5" style={`color: ${siteConfig.accentColor}`}>{edu.school}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
