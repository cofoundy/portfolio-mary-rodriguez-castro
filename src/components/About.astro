---
import { siteConfig } from "../config";
---

<section id="about" class="relative py-12 md:py-16" style={`background-color: ${siteConfig.bgCard}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.03]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Photo -->
      <div class="lg:col-span-4 reveal-left flex justify-center">
        <div class="relative flex flex-col items-center">
          <div class="absolute -inset-3 rounded-2xl opacity-15" style={`background-color: ${siteConfig.highlightColor}`}></div>
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="relative w-56 h-56 md:w-64 md:h-64 lg:w-72 lg:h-72 object-cover object-center rounded-2xl shadow-xl"
            style={`border: 3px solid ${siteConfig.accentColor}`}
          />
          <div class="mt-4 text-center">
            <h3 class="text-lg font-bold text-white">{siteConfig.name}</h3>
            <p class="text-sm" style={`color: ${siteConfig.accentColor}`}>{siteConfig.title}</p>
          </div>
          <!-- Social Links -->
          <div class="flex gap-3 justify-center mt-3">
            <a href={`mailto:${siteConfig.social.email}`} class="icon-hover w-9 h-9 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="Email">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </a>
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="icon-hover w-9 h-9 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}; color: white`} aria-label="LinkedIn">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Bio -->
      <div class="lg:col-span-8 reveal stagger-1">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style={`color: ${siteConfig.accentColor}`}>
          Sobre Mí
        </h2>
        <div class="w-16 h-1 mb-6 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
        <p class="text-base md:text-lg leading-relaxed" style={`color: ${siteConfig.textLight}`}>
          <Fragment set:html={siteConfig.aboutMe} />
        </p>
      </div>
    </div>

    <!-- Skills -->
    <div class="mt-10 pt-8 border-t reveal stagger-2" style="border-color: rgba(255,255,255,0.08)">
      <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style={`color: ${siteConfig.accentColor}`}>
        Especialidades
      </h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.skills.map((skill) => (
          <span
            class="skill-hover px-4 py-2 rounded-full text-sm font-medium cursor-default"
            style={`background-color: ${siteConfig.accentColor}15; color: ${siteConfig.accentColor}; border: 1px solid ${siteConfig.accentColor}30`}
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
