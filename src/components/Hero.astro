---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-[70vh] flex items-center justify-center overflow-hidden" style={`background-color: ${siteConfig.bgDark}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.04]"></div>
  <!-- Gradient overlay -->
  <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${siteConfig.bgDark} 0%, ${siteConfig.bgCard} 40%, ${siteConfig.accentColor}20 100%)`}></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center py-16">
    <!-- Logo MRC — bigger per client request -->
    <div class="hero-photo mb-8">
      <img src="/logo-mrc.png" alt="MRC Learning & Development" class="h-32 md:h-40 lg:h-48 w-auto mx-auto opacity-95">
    </div>

    <!-- Tagline -->
    <h1 class="hero-title text-2xl md:text-3xl lg:text-4xl font-light text-white leading-relaxed max-w-3xl mx-auto mb-4">
      {siteConfig.tagline}
    </h1>

    <!-- Accent line -->
    <div class="w-24 h-1 mx-auto rounded-full mb-8" style={`background: linear-gradient(90deg, ${siteConfig.accentColor}, ${siteConfig.highlightColor})`}></div>

    <!-- CTA → WhatsApp -->
    <a
      href={siteConfig.social.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="hero-cta inline-flex items-center gap-2 px-8 py-3 rounded-full text-white font-medium transition-all duration-300 hover:scale-105 hover:shadow-lg"
      style={`background-color: ${siteConfig.accentColor}`}
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Conversemos
    </a>

    <!-- Stats Row -->
    {siteConfig.stats && siteConfig.stats.length > 0 && (
      <div class="hero-stats grid grid-cols-3 gap-6 md:gap-12 mt-14 pt-8 border-t max-w-2xl mx-auto" style="border-color: rgba(255,255,255,0.1)">
        {siteConfig.stats.map((stat) => (
          <div class="text-center stat-number">
            <div class="text-3xl md:text-4xl lg:text-5xl font-bold" style={`color: ${siteConfig.accentColor}`}>
              {stat.value}
            </div>
            <div class="text-xs md:text-sm mt-1" style={`color: ${siteConfig.textMuted}`}>{stat.label}</div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Accent Bar -->
<div class="w-full h-2 accent-bar-shimmer" style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}></div>
