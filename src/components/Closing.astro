---
import { siteConfig } from "../config";
---

<section class="relative py-10 text-center" style={`background-color: ${siteConfig.bgDark}`}>
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 geo-pattern opacity-[0.03]"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 reveal">
    <blockquote class="text-lg md:text-xl italic leading-relaxed mb-8" style={`color: ${siteConfig.highlightColor}; font-family: 'Montserrat', sans-serif`}>
      &ldquo;{siteConfig.closingQuote}&rdquo;
    </blockquote>
    <!-- Butterfly logo — bigger per client request -->
    <img src="/butterfly.png" alt="MRC Learning & Development" class="h-24 md:h-32 w-auto mx-auto opacity-80">
  </div>
</section>
